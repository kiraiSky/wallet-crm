// Schema inicial — foco em despesas (Fase 1)
// Outras entidades (customers, vehicles, moloni_*) serão adicionadas nas próximas fases

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Usuário do sistema. Sem auth por agora — usamos um OWNER padrão criado no seed.
model User {
  id           String        @id @default(cuid())
  nome         String
  email        String        @unique
  role         UserRole      @default(OWNER)
  createdAt    DateTime      @default(now()) @map("created_at")
  transactions Transaction[]

  @@map("users")
}

enum UserRole {
  OWNER
  EMPLOYEE
}

// Caixas / contas onde o dinheiro entra e sai
model Account {
  id           String        @id @default(cuid())
  nome         String
  tipo         AccountType
  saldoInicial Decimal       @default(0) @map("saldo_inicial") @db.Decimal(12, 2)
  cor          String        @default("emerald") // emerald | violet | orange | sky | rose | amber | teal | zinc
  icone        String        @default("banknote") // nome do ícone lucide
  archived     Boolean       @default(false)
  createdAt    DateTime      @default(now()) @map("created_at")
  transactions Transaction[]

  @@map("accounts")
}

enum AccountType {
  DINHEIRO
  BANCO
  PIX
  CARTAO
}

// Categorias de receita/despesa
model Category {
  id           String          @id @default(cuid())
  nome         String
  tipo         TransactionType
  cor          String          @default("violet")
  icone        String          @default("package")
  archived     Boolean         @default(false)
  createdAt    DateTime        @default(now()) @map("created_at")
  transactions Transaction[]

  @@unique([nome, tipo])
  @@map("categories")
}

enum TransactionType {
  ENTRADA // receita
  SAIDA   // despesa
}

// Lançamentos (entrada/saída de dinheiro)
model Transaction {
  id          String                    @id @default(cuid())
  tipo        TransactionType
  valor       Decimal                   @db.Decimal(12, 2)
  descricao   String
  data        DateTime
  observacao  String?
  accountId   String                    @map("account_id")
  categoryId  String                    @map("category_id")
  userId      String                    @map("user_id")
  account     Account                   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category    Category                  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  user        User                      @relation(fields: [userId], references: [id], onDelete: Restrict)
  attachments TransactionAttachment[]
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")

  @@index([data])
  @@index([tipo, data])
  @@index([accountId])
  @@index([categoryId])
  @@map("transactions")
}

// Anexos (foto/PDF do comprovante)
model TransactionAttachment {
  id            String      @id @default(cuid())
  transactionId String      @map("transaction_id")
  filename      String      // nome original
  storagePath   String      @map("storage_path") // caminho no disco (relativo a UPLOAD_DIR)
  mimeType      String      @map("mime_type")
  size          Int
  uploadedAt    DateTime    @default(now()) @map("uploaded_at")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("transaction_attachments")
}
