// Schema da app Carteira — gestão de oficina mecânica (financeiro + CRM)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Utilizador do sistema (auth via NextAuth Credentials).
model User {
  id           String        @id @default(cuid())
  nome         String
  email        String        @unique
  senha        String        // hash bcrypt
  role         UserRole      @default(EMPLOYEE)
  active       Boolean       @default(true)
  lastLoginAt  DateTime?     @map("last_login_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  transactions Transaction[]
  auditLogs    AuditLog[]

  @@map("users")
}

enum UserRole {
  OWNER
  EMPLOYEE
}

// Contas onde o dinheiro entra e sai
model Account {
  id           String        @id @default(cuid())
  nome         String
  tipo         AccountType
  saldoInicial Decimal       @default(0) @map("saldo_inicial") @db.Decimal(12, 2)
  cor          String        @default("emerald") // emerald | violet | orange | sky | rose | amber | teal | zinc
  icone        String        @default("banknote") // nome do ícone lucide
  archived     Boolean       @default(false)
  createdAt    DateTime      @default(now()) @map("created_at")
  transactions Transaction[]

  @@map("accounts")
}

enum AccountType {
  DINHEIRO
  BANCO
  CARTAO
}

// Categorias de receita/despesa
model Category {
  id           String          @id @default(cuid())
  nome         String
  tipo         TransactionType
  cor          String          @default("violet")
  icone        String          @default("package")
  archived     Boolean         @default(false)
  createdAt    DateTime        @default(now()) @map("created_at")
  transactions Transaction[]

  @@unique([nome, tipo])
  @@map("categories")
}

enum TransactionType {
  ENTRADA // receita
  SAIDA   // despesa
}

// Movimentos (entrada/saída de dinheiro)
model Transaction {
  id          String                    @id @default(cuid())
  tipo        TransactionType
  valor       Decimal                   @db.Decimal(12, 2)
  descricao   String
  data        DateTime
  observacao  String?
  accountId   String                    @map("account_id")
  categoryId  String                    @map("category_id")
  userId      String                    @map("user_id")
  workOrderId String?                   @map("work_order_id")
  customerId  String?                   @map("customer_id")
  account     Account                   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category    Category                  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  user        User                      @relation(fields: [userId], references: [id], onDelete: Restrict)
  workOrder   WorkOrder?                @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  customer    Customer?                 @relation(fields: [customerId], references: [id], onDelete: SetNull)
  attachments TransactionAttachment[]
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")

  @@index([data])
  @@index([tipo, data])
  @@index([accountId])
  @@index([categoryId])
  @@index([workOrderId])
  @@index([customerId])
  @@map("transactions")
}

// Cliente da oficina
model Customer {
  id          String        @id @default(cuid())
  nome        String
  telefone    String?
  email       String?
  nif         String?       // contribuinte (9 dígitos em PT)
  morada      String?
  observacoes String?
  aniversario DateTime?
  tag         CustomerTag   @default(NOVO)
  archived    Boolean       @default(false)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  vehicles     Vehicle[]
  workOrders   WorkOrder[]
  transactions Transaction[]

  @@index([nome])
  @@index([telefone])
  @@index([nif])
  @@map("customers")
}

enum CustomerTag {
  VIP
  RECORRENTE
  NOVO
  INATIVO
}

// Viaturas vinculadas a um cliente
model Vehicle {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  matricula  String   // formato PT: NN-NN-XX / XX-NN-NN / AA-NN-AA
  marca      String
  modelo     String
  ano        Int?
  cor        String?
  km         Int?
  observacoes String?
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@index([customerId])
  @@index([matricula])
  @@map("vehicles")
}

// Folha de obra (work order)
model WorkOrder {
  id            String          @id @default(cuid())
  numero        Int             @unique @default(autoincrement())
  customerId    String          @map("customer_id")
  vehicleId     String?         @map("vehicle_id")

  estado        WorkOrderStatus @default(ABERTA)
  problema      String
  diagnostico   String?
  trabalho      String?
  observacoes   String?

  kmEntrada     Int?            @map("km_entrada")

  dataAbertura  DateTime        @default(now()) @map("data_abertura")
  dataPrevista  DateTime?       @map("data_prevista")
  dataConclusao DateTime?       @map("data_conclusao")

  totalPecas    Decimal         @default(0) @map("total_pecas") @db.Decimal(12, 2)
  totalMaoObra  Decimal         @default(0) @map("total_mao_obra") @db.Decimal(12, 2)
  total         Decimal         @default(0) @db.Decimal(12, 2)

  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  customer      Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicle       Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  items         WorkOrderItem[]
  transactions  Transaction[]

  @@index([estado])
  @@index([customerId])
  @@index([vehicleId])
  @@index([dataAbertura])
  @@map("work_orders")
}

enum WorkOrderStatus {
  ABERTA
  EM_DIAGNOSTICO
  AGUARDA_PECAS
  EM_REPARACAO
  CONCLUIDA
  FATURADA
  CANCELADA
}

model WorkOrderItem {
  id          String            @id @default(cuid())
  workOrderId String            @map("work_order_id")
  tipo        WorkOrderItemType
  descricao   String
  quantidade  Decimal            @default(1) @db.Decimal(8, 2)
  precoUnit   Decimal            @default(0) @map("preco_unit") @db.Decimal(12, 2)
  total       Decimal            @db.Decimal(12, 2)
  createdAt   DateTime           @default(now()) @map("created_at")

  workOrder   WorkOrder          @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@map("work_order_items")
}

enum WorkOrderItemType {
  PECA
  MAO_OBRA
}

// Anexos (foto/PDF do comprovante)
model TransactionAttachment {
  id            String      @id @default(cuid())
  transactionId String      @map("transaction_id")
  filename      String      // nome original
  storagePath   String      @map("storage_path") // caminho no disco (relativo a UPLOAD_DIR)
  mimeType      String      @map("mime_type")
  size          Int
  uploadedAt    DateTime    @default(now()) @map("uploaded_at")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("transaction_attachments")
}

// Registo de auditoria — quem mudou o quê e quando
model AuditLog {
  id         String      @id @default(cuid())
  userId     String?     @map("user_id")
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  action     AuditAction
  summary    String?     // descrição curta legível (ex: "Folha #12 → CONCLUIDA")
  before     Json?
  after      Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  STATUS_CHANGE
}
