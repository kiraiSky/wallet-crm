// Schema da app Carteira — gestão de oficina mecânica (financeiro + CRM)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Utilizador do sistema (auth via NextAuth Credentials).
model User {
  id           String        @id @default(cuid())
  nome         String
  email        String        @unique
  senha        String // hash bcrypt
  role         UserRole      @default(EMPLOYEE)
  active       Boolean       @default(true)
  lastLoginAt  DateTime?     @map("last_login_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  transactions Transaction[]
  auditLogs    AuditLog[]

  @@map("users")
}

enum UserRole {
  OWNER
  EMPLOYEE
}

// Contas onde o dinheiro entra e sai
model Account {
  id                String        @id @default(cuid())
  nome              String
  tipo              AccountType
  saldoInicial      Decimal       @default(0) @map("saldo_inicial") @db.Decimal(12, 2)
  cor               String        @default("emerald") // emerald | violet | orange | sky | rose | amber | teal | zinc
  icone             String        @default("banknote") // nome do ícone lucide
  archived              Boolean       @default(false)
  excluirDasMetricas    Boolean       @default(false) @map("excluir_das_metricas")
  createdAt             DateTime      @default(now()) @map("created_at")
  transactions          Transaction[] @relation("AccountTransactions")
  receivedTransfers     Transaction[] @relation("TransferDestination")

  @@map("accounts")
}

enum AccountType {
  DINHEIRO
  BANCO
  CARTAO
}

// Categorias de receita/despesa (suporta 2 níveis via parentId)
model Category {
  id           String          @id @default(cuid())
  nome         String
  tipo         TransactionType
  cor          String          @default("violet")
  icone        String          @default("package")
  archived     Boolean         @default(false)
  parentId     String?         @map("parent_id")
  parent       Category?       @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]      @relation("CategoryChildren")
  createdAt    DateTime        @default(now()) @map("created_at")
  transactions Transaction[]

  @@unique([nome, tipo, parentId])
  @@index([parentId])
  @@map("categories")
}

enum TransactionType {
  ENTRADA // receita
  SAIDA // despesa
  TRANSFERENCIA // transferência entre contas (sem impacto nas métricas)
}

// Movimentos (entrada/saída de dinheiro)
model Transaction {
  id              String                  @id @default(cuid())
  tipo            TransactionType
  valor           Decimal                 @db.Decimal(12, 2)
  descricao       String
  data            DateTime
  observacao      String?
  accountId       String                  @map("account_id")
  categoryId      String?                 @map("category_id")
  userId          String                  @map("user_id")
  workOrderId     String?                 @map("work_order_id")
  customerId      String?                 @map("customer_id")
  // Pagamento agendado — quando agendado=true, o movimento ainda não foi confirmado
  // e não conta no saldo das contas nem nos KPIs até confirmadoEm ser preenchido.
  toAccountId     String?                 @map("to_account_id")
  agendado        Boolean                 @default(false)
  dataAgendada    DateTime?               @map("data_agendada")
  confirmadoEm    DateTime?               @map("confirmado_em")
  account         Account                 @relation("AccountTransactions", fields: [accountId], references: [id], onDelete: Restrict)
  toAccount       Account?                @relation("TransferDestination", fields: [toAccountId], references: [id], onDelete: SetNull)
  category        Category?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  user            User                    @relation(fields: [userId], references: [id], onDelete: Restrict)
  workOrder       WorkOrder?              @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  customer        Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  attachments     TransactionAttachment[]
  moloniDocuments MoloniDocument[]
  workOrderCaucao WorkOrderCaucao?
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  @@index([data])
  @@index([tipo, data])
  @@index([accountId])
  @@index([categoryId])
  @@index([workOrderId])
  @@index([customerId])
  @@index([agendado, dataAgendada])
  @@index([toAccountId])
  @@map("transactions")
}

// Cliente da oficina
model Customer {
  id          String      @id @default(cuid())
  nome        String
  telefone    String?
  email       String?
  nif         String? // contribuinte (9 dígitos em PT)
  morada      String?
  observacoes String?
  aniversario DateTime?
  tag         CustomerTag @default(NOVO)
  linguagem   String      @default("pt") @map("linguagem")
  archived    Boolean     @default(false)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  vehicles        Vehicle[]
  workOrders      WorkOrder[]
  transactions    Transaction[]
  automationLogs  AutomationLog[]
  moloniDocuments MoloniDocument[]

  @@index([nome])
  @@index([telefone])
  @@index([nif])
  @@map("customers")
}

enum CustomerTag {
  VIP
  RECORRENTE
  NOVO
  INATIVO
}

// Viaturas vinculadas a um cliente
model Vehicle {
  id          String   @id @default(cuid())
  customerId  String   @map("customer_id")
  matricula   String // formato PT: NN-NN-XX / XX-NN-NN / AA-NN-AA
  marca       String
  modelo      String
  ano         Int?
  cor         String?
  km          Int?
  observacoes String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@index([customerId])
  @@index([matricula])
  @@map("vehicles")
}

// Folha de obra (work order)
model WorkOrder {
  id         String  @id @default(cuid())
  numero     Int     @unique @default(autoincrement())
  customerId String  @map("customer_id")
  vehicleId  String? @map("vehicle_id")

  estado      WorkOrderStatus @default(ABERTA)
  problema    String
  diagnostico String?
  trabalho    String?
  observacoes String?

  kmEntrada Int? @map("km_entrada")

  dataAbertura  DateTime  @default(now()) @map("data_abertura")
  dataPrevista  DateTime? @map("data_prevista")
  dataConclusao DateTime? @map("data_conclusao")

  totalPecas   Decimal @default(0) @map("total_pecas") @db.Decimal(12, 2)
  totalMaoObra Decimal @default(0) @map("total_mao_obra") @db.Decimal(12, 2)
  total        Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Moloni — fatura criada a partir desta folha
  moloniDocumentId   Int?    @map("moloni_document_id")
  moloniDocumentType String? @map("moloni_document_type") // ex: "FT", "FR"

  // Partilha pública com cliente (sem login)
  shareToken String? @unique @map("share_token")

  customer       Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicle        Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  items          WorkOrderItem[]
  transactions   Transaction[]
  automationLogs AutomationLog[]
  caucoes        WorkOrderCaucao[]

  @@index([estado])
  @@index([customerId])
  @@index([vehicleId])
  @@index([dataAbertura])
  @@map("work_orders")
}

// Caução / adiantamento — cliente paga parte do serviço antes da conclusão.
// Pode haver várias por folha (ex: 30% na abertura, 30% a meio, etc.).
// Cada caução pode opcionalmente ter:
//   - uma Transaction de ENTRADA associada (entra logo no saldo da conta), e
//   - uma Fatura-Recibo (FR) emitida no Moloni para cumprir o Dec.-Lei 197/2012
//     (IVA exigível no momento do adiantamento).
// Na faturação final, o total a faturar é (WorkOrder.total − Σ cauções.valor).
model WorkOrderCaucao {
  id          String   @id @default(cuid())
  workOrderId String   @map("work_order_id")
  valor       Decimal  @db.Decimal(12, 2)
  data        DateTime
  notas       String?

  // Transação criada quando o utilizador escolhe "criar entrada na conta"
  transactionId String? @unique @map("transaction_id")

  // Fatura-Recibo emitida no Moloni para esta caução
  moloniDocumentId   Int?    @map("moloni_document_id")
  moloniDocumentType String? @map("moloni_document_type") // ex: "FR"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workOrder   WorkOrder    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([workOrderId])
  @@map("work_order_caucoes")
}

enum WorkOrderStatus {
  ABERTA
  EM_DIAGNOSTICO
  AGUARDA_PECAS
  EM_REPARACAO
  CONCLUIDA
  FATURADA
  CANCELADA
  FINALIZADA // obra concluída e entregue — sai do kanban
  PERDIDA    // negócio não fechado — sai do kanban
}

model WorkOrderItem {
  id          String            @id @default(cuid())
  workOrderId String            @map("work_order_id")
  tipo        WorkOrderItemType
  descricao   String
  referencia  String?
  quantidade  Decimal           @default(1) @db.Decimal(8, 2)
  precoUnit   Decimal           @default(0) @map("preco_unit") @db.Decimal(12, 4)
  margem      Decimal?          @db.Decimal(5, 2)
  iva         Decimal?          @db.Decimal(5, 2)
  total       Decimal           @db.Decimal(12, 2)
  createdAt   DateTime          @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@map("work_order_items")
}

enum WorkOrderItemType {
  PECA
  MAO_OBRA
}

// Anexos (foto/PDF do comprovante)
model TransactionAttachment {
  id            String      @id @default(cuid())
  transactionId String      @map("transaction_id")
  filename      String // nome original
  storagePath   String      @map("storage_path") // caminho no disco (relativo a UPLOAD_DIR)
  mimeType      String      @map("mime_type")
  size          Int
  uploadedAt    DateTime    @default(now()) @map("uploaded_at")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("transaction_attachments")
}

// Registo de auditoria — quem mudou o quê e quando
model AuditLog {
  id         String      @id @default(cuid())
  userId     String?     @map("user_id")
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  action     AuditAction
  summary    String? // descrição curta legível (ex: "Folha #12 → CONCLUIDA")
  before     Json?
  after      Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  STATUS_CHANGE
}

model MoloniConnection {
  id               String           @id @default(cuid())
  clientId         String           @map("client_id")
  redirectUri      String           @map("redirect_uri")
  accessToken      String           @map("access_token") @db.Text
  refreshToken     String           @map("refresh_token") @db.Text
  tokenExpiresAt   DateTime         @map("token_expires_at")
  companyId        Int?             @map("company_id")
  companyName      String?          @map("company_name")
  companyVat       String?          @map("company_vat")
  connectedAt      DateTime         @default(now()) @map("connected_at")
  lastSyncAt       DateTime?        @map("last_sync_at")
  // Sync automático
  autoSyncEnabled  Boolean          @default(false) @map("auto_sync_enabled")
  autoSyncInterval Int              @default(60) @map("auto_sync_interval") // minutos
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  documents        MoloniDocument[]
  syncLogs         MoloniSyncLog[]

  @@map("moloni_connections")
}

model MoloniDocument {
  id             String           @id @default(cuid())
  connectionId   String           @map("connection_id")
  documentId     Int              @map("document_id")
  documentTypeId Int              @map("document_type_id")
  documentSetId  Int?             @map("document_set_id")
  documentType   String?          @map("document_type") // ex: "FT", "FR", "ND", "NC"
  number         Int?
  date           DateTime?
  expirationDate DateTime?        @map("expiration_date")
  entityName     String?          @map("entity_name")
  entityVat      String?          @map("entity_vat")
  grossValue     Decimal          @default(0) @map("gross_value") @db.Decimal(12, 2)
  netValue       Decimal          @default(0) @map("net_value") @db.Decimal(12, 2)
  taxesValue     Decimal          @default(0) @map("taxes_value") @db.Decimal(12, 2)
  status         Int?
  saftCode       String?          @map("saft_code")
  raw            Json
  modifiedAt     DateTime?        @map("modified_at")
  // Cruzamentos
  customerId     String?          @map("customer_id")
  transactionId  String?          @map("transaction_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  connection     MoloniConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  customer       Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  transaction    Transaction?     @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@unique([connectionId, documentId])
  @@index([entityVat])
  @@index([date])
  @@index([modifiedAt])
  @@index([customerId])
  @@index([transactionId])
  @@map("moloni_documents")
}

model MoloniSyncLog {
  id             String           @id @default(cuid())
  connectionId   String           @map("connection_id")
  status         MoloniSyncStatus
  message        String?
  documentsSeen  Int              @default(0) @map("documents_seen")
  documentsSaved Int              @default(0) @map("documents_saved")
  startedAt      DateTime         @default(now()) @map("started_at")
  finishedAt     DateTime?        @map("finished_at")
  connection     MoloniConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([startedAt])
  @@map("moloni_sync_logs")
}

enum MoloniSyncStatus {
  SUCCESS
  ERROR
}

// Automações de mensagens CRM
model AutomationTemplate {
  id             String            @id @default(cuid())
  nome           String
  tipo           AutomationType
  trigger        AutomationTrigger
  triggerEstados String            @default("[]") @map("trigger_estados") @db.Text
  mensagem       String            @db.Text
  ativo          Boolean           @default(true)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  logs           AutomationLog[]

  @@map("automation_templates")
}

enum AutomationType {
  FOLLOW_UP
  LEMBRETE_PAGAMENTO
  LEMBRETE_LEVANTAMENTO
  CUSTOM
}

enum AutomationTrigger {
  MANUAL
  STATUS_FOLHA
}

model AutomationLog {
  id              String   @id @default(cuid())
  templateId      String?  @map("template_id")
  templateNome    String   @map("template_nome")
  customerId      String   @map("customer_id")
  workOrderId     String?  @map("work_order_id")
  mensagemEnviada String   @map("mensagem_enviada") @db.Text
  webhookOk       Boolean  @default(false) @map("webhook_ok")
  webhookResponse String?  @map("webhook_response") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  template  AutomationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  customer  Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrder WorkOrder?          @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([templateId])
  @@index([workOrderId])
  @@index([createdAt])
  @@map("automation_logs")
}

// Perfil / dados da empresa (singleton — id fixo "default")
model CompanyProfile {
  id           String   @id @default("default")
  nome         String   @default("")
  nif          String   @default("")
  morada       String   @default("")
  codigoPostal String   @default("") @map("codigo_postal")
  cidade       String   @default("")
  pais         String   @default("Portugal")
  telefone     String   @default("")
  email        String   @default("")
  website      String   @default("")
  logoPath     String?  @map("logo_path")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("company_profile")
}
